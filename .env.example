# Supabase — from your project's API settings (https://app.supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only Supabase service role key (NEVER expose to the browser).
# Used by privileged server actions such as admin role assignment.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — powers the AI assistant agents
ANTHROPIC_API_KEY=sk-ant-...
