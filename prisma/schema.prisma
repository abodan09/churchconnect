generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tenant root ───────────────────────────────────────────────────────────────
// Each row represents one church (one instance of the product).
// Every other model carries church_id and is scoped to exactly one Church.

model Church {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  clerkOrgId String?  @unique
  plan       String   @default("trial") // trial | starter | pro
  is_active  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Users ─────────────────────────────────────────────────────────────────────

model UserProfile {
  id              String   @id @default(cuid())
  clerkId         String   @unique
  church_id       String
  role            String   @default("member")
  departmentId    String?
  phone           String?
  profilePhotoUrl String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Members ───────────────────────────────────────────────────────────────────

model Member {
  id                      String   @id @default(cuid())
  church_id               String
  first_name              String
  last_name               String
  email                   String?
  phone                   String?
  address                 String?
  department_id           String?
  department_name         String?
  join_date               String?
  membership_status       String   @default("active")
  profile_photo_url       String?
  gender                  String?
  date_of_birth           String?
  marital_status          String?
  occupation              String?
  emergency_contact_name  String?
  emergency_contact_phone String?
  notes                   String?
  user_id                 String?
  baptism_date            String?
  membership_class_date   String?
  confirmation_date       String?
  volunteer_status        String?
  background_check_date   String?
  created_by_id           String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ── Departments ───────────────────────────────────────────────────────────────

model Department {
  id                   String   @id @default(cuid())
  church_id            String
  name                 String
  description          String?
  head_name            String?
  head_user_id         String?
  media_upload_enabled Boolean  @default(false)
  allowed_media_types  String   @default("none")
  is_active            Boolean  @default(true)
  color                String?
  allowed_features     String?
  created_by_id        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ── Events ────────────────────────────────────────────────────────────────────

model Event {
  id              String   @id @default(cuid())
  church_id       String
  title           String
  description     String?
  department_id   String?
  department_name String?
  start_datetime  String
  end_datetime    String?
  location        String?
  event_type      String   @default("service")
  is_public       Boolean  @default(true)
  created_by_name String?
  created_by_id   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Giving ────────────────────────────────────────────────────────────────────

model Giving {
  id               String   @id @default(cuid())
  church_id        String
  member_id        String
  member_name      String?
  date             String
  amount           Float
  type             String   @default("tithe")
  payment_method   String   @default("cash")
  service_or_event String?
  notes            String?
  recorded_by      String?
  created_by_id    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ── Expenditures ──────────────────────────────────────────────────────────────

model Expenditure {
  id              String   @id @default(cuid())
  church_id       String
  date            String
  category        String
  description     String
  amount          Float
  department_id   String?
  department_name String?
  approval_status String   @default("pending")
  approved_by     String?
  approved_date   String?
  receipt_url     String?
  notes           String?
  created_by_id   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Attendance ────────────────────────────────────────────────────────────────

model Attendance {
  id              String   @id @default(cuid())
  church_id       String
  event_id        String
  event_name      String?
  event_date      String?
  member_id       String
  member_name     String?
  department_id   String?
  department_name String?
  check_in_time   String?
  status          String   @default("present")
  checked_in_by   String?
  notes           String?
  created_by_id   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Sermons ───────────────────────────────────────────────────────────────────

model Sermon {
  id               String   @id @default(cuid())
  church_id        String
  title            String
  description      String?
  preacher         String
  date             String
  department_id    String?
  department_name  String?
  media_type       String?
  file_url         String?
  thumbnail_url    String?
  duration_minutes Float?
  tags             String?
  created_by_id    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ── Properties ────────────────────────────────────────────────────────────────

model Property {
  id                       String   @id @default(cuid())
  church_id                String
  type                     String
  name                     String
  description              String?
  location_or_serial       String?
  purchase_date            String?
  purchase_value           Float?
  current_condition        String?
  assigned_department_id   String?
  assigned_department_name String?
  maintenance_notes        String?
  photo_url                String?
  created_by_id            String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

// ── Church Settings ───────────────────────────────────────────────────────────

model ChurchSettings {
  id              String   @id @default(cuid())
  church_id       String   @unique
  church_name     String
  logo_url        String?
  language        String   @default("en")
  currency_code   String   @default("EUR")
  currency_symbol String   @default("€")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Access Requests ───────────────────────────────────────────────────────────

model AccessRequest {
  id               String   @id @default(cuid())
  church_id        String
  clerk_id         String?
  name             String
  email            String
  social_platform  String   @default("other")
  social_handle    String?
  message          String?
  status           String   @default("pending")
  requested_at     String?
  reviewed_by      String?
  reviewed_at      String?
  rejection_reason String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ── Small Groups ──────────────────────────────────────────────────────────────

model SmallGroup {
  id                String   @id @default(cuid())
  church_id         String
  name              String
  type              String   @default("bible_study")
  description       String?
  leader_id         String?
  leader_name       String?
  co_leader_name    String?
  meeting_day       String?
  meeting_time      String?
  meeting_frequency String   @default("weekly")
  location          String?
  max_capacity      Int?
  is_active         Boolean  @default(true)
  is_open           Boolean  @default(true)
  department_id     String?
  department_name   String?
  notes             String?
  created_by_id     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SmallGroupMember {
  id            String   @id @default(cuid())
  church_id     String
  group_id      String
  group_name    String?
  member_id     String
  member_name   String?
  role          String   @default("member")
  joined_date   String?
  is_active     Boolean  @default(true)
  notes         String?
  created_by_id String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Pastoral Care ─────────────────────────────────────────────────────────────

model PastoralCare {
  id               String   @id @default(cuid())
  church_id        String
  member_id        String?
  member_name      String?
  type             String   @default("prayer_request")
  date             String
  description      String
  status           String   @default("open")
  priority         String   @default("normal")
  assigned_to      String?
  assigned_name    String?
  resolved_date    String?
  resolution_notes String?
  is_private       Boolean  @default(false)
  submitted_by     String?
  created_by_id    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ── Volunteers ────────────────────────────────────────────────────────────────

model Volunteer {
  id              String   @id @default(cuid())
  church_id       String
  member_id       String
  member_name     String?
  event_id        String?
  event_name      String?
  event_date      String?
  department_id   String?
  department_name String?
  role            String?
  status          String   @default("pending")
  notes           String?
  checked_in      Boolean  @default(false)
  created_by_id   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Announcements ─────────────────────────────────────────────────────────────

model Announcement {
  id              String   @id @default(cuid())
  church_id       String
  title           String
  content         String
  audience        String   @default("all")
  department_id   String?
  department_name String?
  published_by    String?
  publish_date    String?
  expiry_date     String?
  is_pinned       Boolean  @default(false)
  priority        String   @default("normal")
  is_active       Boolean  @default(true)
  created_by_id   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
